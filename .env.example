# Application Environment
NODE_ENV=development
PORT=3001
FASTAPI_PORT=8000
SPRINGBOOT_PORT=8080
FRONTEND_PORT=3000

# Database URLs
MONGODB_URI=mongodb://mongodb:27017/fintech
POSTGRES_URI=postgresql://postgres:postgres@postgres:5432/fintech
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Vector Database (Pinecone)
PINCONE_API_KEY=your-pinecone-api-key
PINCONE_ENVIRONMENT=us-west1-gcp
PINCONE_INDEX_NAME=financial-analytics

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=fintech-analytics-bucket

# Service URLs (for inter-service communication)
NODE_API_URL=http://backend-node:3001
FASTAPI_URL=http://backend-fastapi:8000
SPRINGBOOT_URL=http://backend-springboot:8080

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Feature Flags
ENABLE_AI_PIPELINE=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_REAL_TIME_UPDATES=true